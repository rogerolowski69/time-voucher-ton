{
  "name": "time-voucher-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c green,cyan \"astro dev\" \"npm run dev:api\"",
    "dev:web": "astro dev",
    "dev:api": "cd api && .venv/bin/uvicorn main:app --reload --host 127.0.0.1 --port 8787",
    "build": "astro build",
    "preview": "astro build && cd api && .venv/bin/uvicorn main:app --host 0.0.0.0 --port ${PORT:-8787}",
    "start": "cd api && .venv/bin/uvicorn main:app --host 0.0.0.0 --port ${PORT:-8787}"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "@astrojs/tailwind": "^6.0.2",
    "@headlessui/react": "^2.2.9",
    "@ton/core": "^0.63.1",
    "@ton/ton": "^16.2.4",
    "@tonconnect/ui": "^2.4.4",
    "@twa-dev/sdk": "^8.0.2",
    "astro": "^5.18.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "preact": "^10.27.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3"
  }
}
