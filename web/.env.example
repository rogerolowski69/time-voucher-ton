# --- Build-time (Astro) — set in Railway Variables BEFORE deploy ---
# These are baked into the static bundle at `npm run build`.
PUBLIC_MINTER_ADDRESS=
PUBLIC_NFT_ITEM_ADDRESS=
PUBLIC_NETWORK=testnet
PUBLIC_GAS_BUFFER_TON=0.3
PUBLIC_REDEEM_ADDRESS=
PUBLIC_CAL_COM_URL=https://cal.com/your-link
PUBLIC_ISSUER_EMAIL=you@example.com
PUBLIC_TONCENTER_API_KEY=
PUBLIC_TELEGRAM_BOT_USERNAME=your_bot

# --- Runtime (FastAPI) — Railway service variables ---
TELEGRAM_BOT_TOKEN=
# Optional — set same value in setWebhook secret_token and Railway
TELEGRAM_WEBHOOK_SECRET=
ADMIN_API_TOKEN=change-me
DATA_DIR=/data
TONCENTER_API_KEY=
LOG_LEVEL=INFO
LOG_JSON=true

# Optional — auto-detected from RAILWAY_PUBLIC_DOMAIN if unset
# PUBLIC_URL=https://your-app.up.railway.app

# Local dev only — set so TonConnect manifest url matches Astro (localhost:4321)
PUBLIC_URL=http://localhost:4321
PORT=8787
